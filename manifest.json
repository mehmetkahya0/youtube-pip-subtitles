{
  "manifest_version": 3,
  "name": "YouTube PiP Subtitles",
  "version": "1.0.0",
  "description": "YouTube PiP modunda altyazıları videonun içinde gösterir.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PiP Subtitle Ayarları"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
